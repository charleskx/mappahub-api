{
  "name": "atlasync",
  "version": "0.1.9",
  "private": true,
  "scripts": {
    "dev": "tsx watch server.ts",
    "dev:worker": "tsx watch worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-super-admin": "tsx src/db/seed-super-admin.ts",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/lib-storage": "^3.1050.0",
    "@casl/ability": "^6.7.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@sentry/node": "^10.53.1",
    "@types/speakeasy": "^2.0.10",
    "argon2": "^0.40.3",
    "bullmq": "^5.13.0",
    "dayjs": "^1.11.12",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.4.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.12.0",
    "pino-pretty": "^11.2.2",
    "pm2": "^7.0.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "stripe": "^16.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
