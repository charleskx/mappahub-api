NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://user:password@localhost:5432/atlasync
REDIS_URL=redis://localhost:6379

# mínimo 32 caracteres
JWT_SECRET=

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
# Pacotes de créditos extras de geocoding (Stripe Price em modo "one-time")
STRIPE_PRICE_GEO_1K=price_...
STRIPE_PRICE_GEO_5K=price_...
STRIPE_PRICE_GEO_10K=price_...
STRIPE_PRICE_GEO_25K=price_...

APP_URL=http://localhost:3000

GOOGLE_MAPS_API_KEY=

# Cloudflare R2 (opcional — necessário para upload de logo no mapa público)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Origens permitidas no CORS — obrigatório em produção (separadas por vírgula)
# CORS_ORIGIN=https://app.mappahub.com.br

# Chave AES-256-GCM para cifrar segredos TOTP no banco (recomendado em produção)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOTP_ENCRYPTION_KEY=

# SMTP (obrigatório em produção)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...
SMTP_FROM=MappaHub <noreply@mappahub.com.br>
